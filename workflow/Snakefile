from pathlib import Path
import os

configfile: "config/config.yaml"

include: "rules/common.smk"
include: "rules/reference.smk"
include: "rules/intervals.smk"
include: "rules/fastq.smk"
include: "rules/mapping.smk"
include: "rules/qc_metrics.smk"
include: "rules/callable_sites.smk"

if USE_SENTIEON:
    include: "rules/variant_calling/sentieon.smk"
else:
    if config["intervals"]["enabled"]:
        include: "rules/variant_calling/gatk_intervals.smk"
    else:
        include: "rules/variant_calling/gatk.smk"


rule all:
    """Default target: full pipeline."""
    input:
        "results/vcfs/raw.vcf.gz",
        "results/qc_metrics/qc_report.tsv",
        "results/callable_sites/callable_loci.zarr" if config["callable_sites"]["coverage"]["enabled"] else [],
        "results/callable_sites/mappability.bed" if config["callable_sites"]["mappability"]["enabled"] else [],


rule setup:
    """
    Prepare reference, indices, and intervals.
    Resolves checkpoints so subsequent runs can build the full DAG.
    """
    input:
        REF_FILES["ref"],
        REF_FILES["ref_fai"],
        REF_FILES["ref_dict"],
        REF_BWA_IDX,
        "results/intervals/gvcf/intervals.txt" if config["intervals"]["enabled"] else [],
        "results/intervals/db/intervals.txt" if config["intervals"]["enabled"] else []

rule download_reads:
    """Download fastqs for all SRA samples."""
    input:
        [
            f"results/fastqs/{record['sample_id']}/{record['library_id']}/{record['input_unit']}/{record['input']}_{read}.fastq.gz"
            for sample in SAMPLES_SRR
            for record in get_sample_srr_records(sample)
            for read in [1, 2]
        ] if SAMPLES_SRR else [],


rule map_samples:
    """Align all samples that need alignment."""
    input:
        [get_final_bam(s) for s in SAMPLES_NEED_ALIGNMENT],


rule call_variants:
    """Run variant calling through to filtered VCF."""
    input:
        "results/vcfs/filtered.vcf.gz",


rule qc_report:
    """Generate QC metrics report."""
    input:
        "results/qc_metrics/qc_report.tsv",


rule callable_sites:
    """Generate callable sites from coverage and mappability."""
    input:
        "results/callable_sites/callable_loci.zarr",
        "results/callable_sites/mappability.bed",


rule gvcfs:
    """Generate normalized gVCFs for all samples."""
    input:
        expand("results/gvcfs_norm/{sample}.g.vcf.gz", sample=SAMPLES_ALL),
