"""
snpArcher v2 - Population genomic variant calling workflow.

A Snakemake workflow for generating variant calls from raw sequence data.
Supports both GATK and Sentieon pipelines.
"""

configfile: "config/config.yaml"

include: "rules/common.smk"

setup_curlrc()
onerror: cleanup_curlrc()
onsuccess: cleanup_curlrc()

include: "rules/reference.smk"
include: "rules/fastq.smk"
include: "rules/stats/sumstats.smk"

if config["variant_calling"]["tool"] == "sentieon":
    include: "rules/align/sentieon.smk"
else:
    include: "rules/align/bwa.smk"

if config["variant_calling"]["tool"] == "sentieon":
    include: "rules/call/sentieon.smk"
else:
    if config["intervals"]["enabled"]:
        include: "rules/call/intervals.smk"
        include: "rules/call/gatk_intervals.smk"
    else:
        include: "rules/call/gatk.smk"

include: "rules/filter/mappability.smk"

if config["callable_sites"]["coverage"]["enabled"]:
    include: "rules/filter/coverage.smk"


if config.get("modules", {}).get("qc", {}).get("enabled", False):
    module qc:
        snakefile:
            "modules/qc/Snakefile"
        config:
            config

if config.get("modules", {}).get("postprocess", {}).get("enabled", False):
    module postprocess:
        snakefile:
            "modules/postprocess/Snakefile"
        config:
            config

if config.get("modules", {}).get("trackhub", {}).get("enabled", False):
    if not config.get("modules", {}).get("postprocess", {}).get("enabled", False):
        raise WorkflowError(
            "trackhub module requires postprocess module to be enabled. "
            "Enable modules.postprocess.enabled or disable modules.trackhub.enabled."
        )
    module trackhub:
        snakefile:
            "modules/trackhub/Snakefile"
        config:
            config


def get_output():
    """Determine workflow output based on configuration."""
    outputs = []
    outputs.append(f"results/{REF_NAME}_raw.vcf.gz")
    outputs.append(f"results/{REF_NAME}_raw.vcf.gz.tbi")
    outputs.append(f"results/summary_stats/{REF_NAME}_bam_sumstats.txt")
    outputs.append(f"results/{REF_NAME}_callable_sites.bed")
    return outputs


rule all:
    input:
        get_output(),
    default_target: True


rule vcf:
    input:
        vcf=f"results/{REF_NAME}_raw.vcf.gz",
        tbi=f"results/{REF_NAME}_raw.vcf.gz.tbi",


rule bams:
    input:
        expand("results/bams/{sample}.bam", sample=SAMPLE_IDS),
        expand("results/bams/{sample}.bam.bai", sample=SAMPLE_IDS),


rule gvcfs:
    input:
        expand("results/gvcfs/{sample}.g.vcf.gz", sample=SAMPLE_IDS),
        expand("results/gvcfs/{sample}.g.vcf.gz.tbi", sample=SAMPLE_IDS),


rule stats:
    input:
        f"results/summary_stats/{REF_NAME}_bam_sumstats.txt",


rule callable_sites:
    input:
        f"results/{REF_NAME}_callable_sites.bed",
