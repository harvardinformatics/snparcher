"""
snpArcher v2 — MK (McDonald-Kreitman) Module

Runs degenotate to produce a McDonald-Kreitman divergence table from a
filtered VCF, reference FASTA, and GFF annotation.

Can run standalone:
    snakemake --snakefile workflow/modules/mk/Snakefile \
        --config vcf=path/to/filtered.vcf.gz ref=path/to/ref.fa.gz gff=path/to/annotation.gff

Or imported by the main workflow via Snakemake's `module` directive
(config is passed in, overriding the configfile below).

Config keys (flat):
    samples           - path to samples CSV (required)
    sample_metadata   - path to metadata CSV (optional, for outgroup/exclude columns)
    vcf               - path to filtered VCF input (required)
    ref               - path to reference FASTA, may be bgzipped .fa.gz (required)
    gff               - path to GFF annotation file (required)
"""

import pandas as pd

# When imported via `module ... config: config`, this configfile is ignored.
configfile: "config/config.yaml"

_MK_DEFAULTS = {
    "samples": "config/samples.csv",
    "sample_metadata": "",
    "vcf": "results/postprocess/filtered.vcf.gz",
    "ref": "results/reference/ref.fa.gz",
    "gff": "",
}

for _k, _v in _MK_DEFAULTS.items():
    if _k not in config:
        config[_k] = _v


# ---------- Validation -------------------------------------------------------

if not config.get("gff", ""):
    raise WorkflowError(
        "MK module requires a GFF annotation file. "
        "Set the 'gff' config key to the path of your GFF file."
    )


# ---------- Sample sheet + metadata ------------------------------------------

_samples_df = pd.read_csv(config["samples"])
_ALL_SAMPLES = _samples_df["sample_id"].unique().tolist()

_metadata_df = None
_meta_path = config.get("sample_metadata", "")
if _meta_path:
    _metadata_df = pd.read_csv(_meta_path)


def _get_excluded_samples():
    """Return sample_ids where exclude=True. Empty list if no metadata."""
    if _metadata_df is None or "exclude" not in _metadata_df.columns:
        return []
    return _metadata_df.loc[_metadata_df["exclude"].astype(bool), "sample_id"].tolist()


def _get_outgroup_samples():
    """Return sample_ids where outgroup=True. Empty list if no metadata."""
    if _metadata_df is None or "outgroup" not in _metadata_df.columns:
        return []
    return _metadata_df.loc[_metadata_df["outgroup"].astype(bool), "sample_id"].tolist()


def _ref_is_gzipped():
    """Check if the reference path ends with .gz (needs decompression)."""
    return config["ref"].endswith(".gz")


# ---------- Rules ------------------------------------------------------------


rule all:
    input:
        "results/mk/mk_table.tsv",


rule decompress_ref:
    """Decompress bgzipped reference FASTA for degenotate (requires uncompressed)."""
    input:
        ref=config["ref"],
    output:
        ref="results/mk/ref.fna",
    conda:
        "envs/mk.yml"
    shell:
        """
        if [[ "{input.ref}" == *.gz ]]; then
            gunzip -c {input.ref} > {output.ref}
        else
            cp {input.ref} {output.ref}
        fi
        """


rule copy_gff:
    """Copy GFF annotation into the MK results directory."""
    input:
        gff=config["gff"],
    output:
        gff="results/mk/ref.gff",
    shell:
        """
        cp {input.gff} {output.gff}
        """


rule split_samples:
    """
    Write exclude and outgroup sample lists from metadata.
    If no metadata is provided, both files are empty (all samples are ingroup).
    """
    output:
        exclude="results/mk/exclude.txt",
        outgroups="results/mk/outgroups.txt",
    run:
        excluded = _get_excluded_samples()
        outgroups = _get_outgroup_samples()
        with open(output.exclude, "w") as f:
            for s in excluded:
                f.write(s + "\n")
        with open(output.outgroups, "w") as f:
            for s in outgroups:
                f.write(s + "\n")


rule degenotate:
    """Run degenotate to compute McDonald-Kreitman divergence table."""
    input:
        vcf=config["vcf"],
        genome="results/mk/ref.fna",
        gff="results/mk/ref.gff",
        exclude="results/mk/exclude.txt",
        outgroups="results/mk/outgroups.txt",
    output:
        "results/mk/mk_table.tsv",
    params:
        outdir="results/mk/degen_raw",
        delim="space",
    log:
        "logs/mk/degenotate.txt",
    conda:
        "envs/mk.yml"
    shell:
        """
        if [ -s {input.exclude} ]; then
            degenotate.py --overwrite \
                -a {input.gff} -g {input.genome} \
                -u {input.outgroups} -e {input.exclude} \
                -d {params.delim} \
                -o {params.outdir} \
                -v {input.vcf} 2>&1 | tee {log}
        else
            degenotate.py --overwrite \
                -a {input.gff} -g {input.genome} \
                -u {input.outgroups} \
                -d {params.delim} \
                -o {params.outdir} \
                -v {input.vcf} 2>&1 | tee {log}
        fi
        cp {params.outdir}/mk.tsv {output}
        """
