"""
snpArcher v2 — QC Module

Produces an interactive QC dashboard (PCA, admixture, NJ tree, relatedness,
mapping rate, heterozygosity, geographic maps) from a raw VCF.

Can run standalone:
    snakemake --snakefile workflow/modules/qc/Snakefile --config vcf=path/to/raw.vcf.gz fai=path/to/ref.fai

Or imported by the main workflow via Snakemake's `module` directive
(config is passed in, overriding the configfile below).

Config keys (flat):
    samples           - path to samples CSV (required)
    sample_metadata   - path to metadata CSV (optional, for lat/long coords)
    vcf               - path to raw VCF input (required)
    fai               - path to reference .fai index (required)
    qc_report         - path to BAM summary stats TSV (optional; empty = skip mapping rate panel)
    clusters          - number of k-means clusters for PCA visualization (default 3)
    min_depth         - minimum depth to include a sample (default 2)
    google_api_key    - Google Maps API key for terrain map (default "")
    exclude_scaffolds - comma-separated scaffolds to exclude (default "")
"""

import os
import tempfile
import pandas as pd

# When imported via `module ... config: config`, this configfile is ignored.
configfile: "config/config.yaml"

_QC_DEFAULTS = {
    "samples": "config/samples.csv",
    "sample_metadata": "",
    "vcf": "results/vcfs/raw.vcf.gz",
    "fai": "results/reference/ref.fa.gz.fai",
    "qc_report": "",
    "clusters": 3,
    "min_depth": 2,
    "google_api_key": "",
    "exclude_scaffolds": "",
}

for _k, _v in _QC_DEFAULTS.items():
    if _k not in config:
        config[_k] = _v


# ---------- Sample sheet + metadata ------------------------------------------

_SAMPLE_SHEET_DTYPES = {
    "sample_id": "string",
    "library_id": "string",
}

_SAMPLE_METADATA_DTYPES = {
    "sample_id": "string",
}


def _read_csv_safe(path, dtype_map):
    """Read a CSV, restricting dtype overrides to columns actually present."""
    present = set(pd.read_csv(path, nrows=0).columns)
    return pd.read_csv(path, dtype={k: v for k, v in dtype_map.items() if k in present})


_samples_df = _read_csv_safe(config["samples"], _SAMPLE_SHEET_DTYPES)
_ALL_SAMPLES = _samples_df["sample_id"].unique().tolist()

_metadata_df = None
_meta_path = config.get("sample_metadata", "")
if _meta_path:
    _metadata_df = pd.read_csv(_meta_path, dtype=_SAMPLE_METADATA_DTYPES)


def _has_coords():
    """Check if metadata has lat/long columns with at least one valid row."""
    if _metadata_df is None:
        return False
    if "lat" not in _metadata_df.columns or "long" not in _metadata_df.columns:
        return False
    return _metadata_df[["lat", "long"]].dropna().shape[0] > 0


def _has_qc_report():
    """Check if BAM summary stats are available."""
    return bool(config.get("qc_report", ""))


def _get_coords_input(wildcards):
    """Return coords file as input if coordinates are available."""
    if _has_coords():
        return {"coords": "results/qc/coords.txt"}
    return {}


def _load_contig_map(path):
    """Load the QC contig map and validate the required columns."""
    contig_map = pd.read_table(path, sep="\t")
    required_cols = {"original_contig", "plink_contig", "admixture_id"}
    missing = required_cols - set(contig_map.columns)
    if missing:
        raise ValueError(f"Contig map is missing required column(s): {sorted(missing)}")
    return contig_map


# ---------- rule all (standalone entry point) --------------------------------

rule all:
    input:
        "results/qc/qc_dashboard.html",


# ---------- Rules ------------------------------------------------------------

rule contig_map:
    """Generate a QC-local contig map for PLINK and ADMIXTURE."""
    input:
        fai=config["fai"],
    output:
        map="results/qc/contig_map.tsv",
    run:
        dffai = pd.read_table(input.fai, sep="\t", header=None, usecols=[0], names=["original_contig"])
        if dffai.empty:
            raise ValueError(f"Reference FAI is empty: {input.fai}")

        all_numeric = pd.to_numeric(dffai["original_contig"], errors="coerce").notnull().all()
        if all_numeric:
            dffai["plink_contig"] = [f"qcctg{i}" for i in range(1, len(dffai) + 1)]
        else:
            dffai["plink_contig"] = dffai["original_contig"]

        dffai["admixture_id"] = range(1, len(dffai) + 1)
        dffai.to_csv(output.map, sep="\t", index=False)


rule vcftools_individuals:
    """Compute per-individual depth, missingness, het, and filter summary."""
    input:
        vcf=config["vcf"],
    output:
        depth="results/qc/individuals.idepth",
        miss="results/qc/individuals.imiss",
        samps="results/qc/individuals.samps.txt",
        summ="results/qc/individuals.FILTER.summary",
        het="results/qc/individuals.het",
    conda:
        "envs/vcftools_individuals.yml"
    params:
        prefix="results/qc/individuals",
        min_depth=config["min_depth"],
    log:
        "logs/qc/vcftools_individuals.txt",
    shell:
        """
        vcftools --gzvcf {input.vcf} --FILTER-summary --out {params.prefix} &> {log}
        vcftools --gzvcf {input.vcf} --out {params.prefix} --depth &>> {log}
        vcftools --gzvcf {input.vcf} --out {params.prefix} --het &>> {log}
        vcftools --gzvcf {input.vcf} --out {params.prefix} --missing-indv &>> {log}
        tail -n +2 {output.depth} | awk '$3>{params.min_depth} {{print $1}}' > {output.samps} 2>> {log}
        """


rule subsample_snps:
    """
    Filter VCF to biallelic SNPs, remove low-quality sites, then prune
    to ~100k SNPs for downstream PCA/admixture/tree analyses.
    """
    input:
        vcf=config["vcf"],
        samps="results/qc/individuals.samps.txt",
        fai=config["fai"],
    output:
        filtered=temp("results/qc/filtered.vcf.gz"),
        filtered_idx=temp("results/qc/filtered.vcf.gz.csi"),
        pruned="results/qc/pruned.vcf.gz",
        snpqc="results/qc/snpqc.txt",
    conda:
        "envs/subsample_snps.yml"
    params:
        chr_ex=config["exclude_scaffolds"],
    log:
        "logs/qc/subsample_snps.txt",
    shell:
        """
        ## Remove filtered sites, retain only biallelic SNPs
        ## Also remove MAF < 0.01, >75% missing, indels, ref=N
        if [ -z "{params.chr_ex}" ]
        then
            bcftools view -S {input.samps} -v snps -m2 -M2 -f .,PASS \
                -e 'AF==1 | AF==0 | AF<0.01 | ALT="*" | F_MISSING > 0.75 | TYPE~"indel" | ref="N"' \
                {input.vcf} -O z -o {output.filtered} &> {log}
        else
            bcftools view -S {input.samps} -t ^{params.chr_ex} -v snps -m2 -M2 -f .,PASS \
                -e 'AF==1 | AF==0 | AF<0.01 | ALT="*" | F_MISSING > 0.75 | TYPE~"indel" | ref="N"' \
                {input.vcf} -O z -o {output.filtered} &> {log}
        fi
        bcftools index {output.filtered} &>> {log}

        # Figure out window size to get ~100k SNPs
        ALLSITES=$(bcftools query -f '%CHROM\\t%POS\\n' {output.filtered} | wc -l)
        SITES=$(( ${{ALLSITES}} / 100000 ))

        # If < 150k SNPs, take all; otherwise prune
        if [[ $SITES -gt 1 ]]
        then
            bcftools +prune -w $SITES -n 1 -N rand -O z -o {output.pruned} {output.filtered} &>> {log}
        else
            bcftools view -O z -o {output.pruned} {output.filtered} &>> {log}
        fi

        bcftools query -f '%CHROM\\t%POS\\t%ID\\t%INFO/AF\\t%QUAL\\t%INFO/ReadPosRankSum\\t%INFO/FS\\t%INFO/SOR\\t%INFO/MQ\\t%INFO/MQRankSum\\n' \
            {output.pruned} > {output.snpqc} 2>> {log}
        """


rule prepare_plink_inputs:
    """Normalize QC-local contig labels for PLINK and copy the matching FAI."""
    input:
        vcf="results/qc/pruned.vcf.gz",
        contig_map="results/qc/contig_map.tsv",
        fai=config["fai"],
    output:
        vcf="results/qc/plink_input.vcf.gz",
        vcf_idx="results/qc/plink_input.vcf.gz.csi",
        fai="results/qc/ref.fai",
    conda:
        "envs/subsample_snps.yml"
    log:
        "logs/qc/prepare_plink_inputs.txt"
    run:
        contig_map = _load_contig_map(input.contig_map)
        rename_map = dict(
            zip(contig_map["original_contig"], contig_map["plink_contig"], strict=True)
        )

        with open(input.fai) as src, open(output.fai, "w") as dst:
            for line in src:
                fields = line.rstrip("\n").split("\t")
                if fields:
                    fields[0] = rename_map.get(fields[0], fields[0])
                dst.write("\t".join(fields) + "\n")

        with tempfile.NamedTemporaryFile(
            "w",
            delete=False,
            dir=os.getcwd(),
            suffix=".rename.tsv",
        ) as rename_file:
            for original, plink_name in rename_map.items():
                rename_file.write(f"{original}\t{plink_name}\n")
            rename_path = rename_file.name

        try:
            shell(
                "bcftools annotate --rename-chrs {rename_path} {input.vcf} "
                "-O z -o {output.vcf} &> {log}"
            )
            shell("bcftools index {output.vcf} &>> {log}")
        finally:
            os.unlink(rename_path)


rule copy_qc_report:
    """
    Copy BAM summary stats into QC folder for the dashboard.
    Only runs when qc_report config key is set.
    """
    input:
        qc_report=config["qc_report"] if _has_qc_report() else [],
    output:
        qc_report="results/qc/qc_report.tsv",
    run:
        import shutil
        shutil.copy2(input.qc_report, output.qc_report)


rule plink:
    """Run PCA, distance matrix, and KING relatedness via plink."""
    input:
        vcf="results/qc/plink_input.vcf.gz",
        vcf_idx="results/qc/plink_input.vcf.gz.csi",
    output:
        bed="results/qc/plink.bed",
        bim="results/qc/plink.bim",
        fam="results/qc/plink.fam",
        eigenvec="results/qc/plink.eigenvec",
        eigenval="results/qc/plink.eigenval",
        dist="results/qc/plink.dist",
        distid="results/qc/plink.dist.id",
        king="results/qc/plink.king",
    params:
        prefix="results/qc/plink",
    conda:
        "envs/plink.yml"
    log:
        "logs/qc/plink.txt",
    shell:
        """
        plink2 --vcf {input.vcf} --pca 10 --out {params.prefix} \
            --allow-extra-chr --autosome-num 95 --make-bed --make-king square \
            --const-fid --bad-freqs &> {log}
        plink --vcf {input.vcf} --out {params.prefix} \
            --allow-extra-chr --autosome-num 95 --distance square \
            --const-fid &>> {log}
        """


rule setup_admixture:
    """
    Admixture requires integer chromosome names.
    Back up original .bim, then remap contig names to 1..N.
    """
    input:
        bim="results/qc/plink.bim",
        contig_map="results/qc/contig_map.tsv",
    output:
        bim="results/qc/plink.bim_fixed",
        bim_back="results/qc/plink.bim.orig",
    script:
        "scripts/contigs4admixture.py"


rule admixture:
    """Run ADMIXTURE for K=2 and K=3."""
    input:
        bed="results/qc/plink.bed",
        bim="results/qc/plink.bim",
        fam="results/qc/plink.fam",
        bim_fixed="results/qc/plink.bim_fixed",
        bim_back="results/qc/plink.bim.orig",
    output:
        admix3="results/qc/plink.3.Q",
        admix2="results/qc/plink.2.Q",
    params:
        outdir=lambda wc, input: os.path.dirname(input.bed),
    log:
        "logs/qc/admixture.txt",
    conda:
        "envs/admixture.yml"
    shell:
        """
        cp {input.bim_fixed} {input.bim} 2> {log}

        admixture {input.bed} 2 &>> {log}
        admixture {input.bed} 3 &>> {log}

        mv plink.2.* {params.outdir} &>> {log}
        mv plink.3.* {params.outdir} &>> {log}
        """


rule generate_coords_file:
    """
    Generate coordinates file from sample metadata (lat/long columns).
    Only runs when metadata with lat/long is available.
    """
    output:
        coords="results/qc/coords.txt",
    run:
        if _metadata_df is not None:
            out_df = _metadata_df[["sample_id", "long", "lat"]].copy()
            out_df.drop_duplicates("sample_id", inplace=True)
            out_df.dropna(subset=["long", "lat"], inplace=True)
            out_df.to_csv(output.coords, index=False, sep="\t", header=False)
        else:
            # Should not reach here since rule only runs when _has_coords() is True
            with open(output.coords, "w") as f:
                pass


rule qc_dashboard:
    """Render the interactive QC dashboard."""
    input:
        unpack(_get_coords_input),
        eigenvec="results/qc/plink.eigenvec",
        eigenval="results/qc/plink.eigenval",
        depth="results/qc/individuals.idepth",
        dist="results/qc/plink.dist",
        distid="results/qc/plink.dist.id",
        king="results/qc/plink.king",
        miss="results/qc/individuals.imiss",
        admix3="results/qc/plink.3.Q",
        admix2="results/qc/plink.2.Q",
        snpqc="results/qc/snpqc.txt",
        bed="results/qc/plink.bed",
        bim="results/qc/plink.bim",
        fam="results/qc/plink.fam",
        summ="results/qc/individuals.FILTER.summary",
        het="results/qc/individuals.het",
        fai="results/qc/ref.fai",
        qc_report="results/qc/qc_report.tsv" if _has_qc_report() else [],
    params:
        qc_dir="results/qc",
        clusters=config["clusters"],
        google_api_key=config["google_api_key"],
        has_qc_report=_has_qc_report(),
    output:
        dashboard="results/qc/qc_dashboard.html",
    conda:
        "envs/qc.yml"
    script:
        "scripts/qc_dashboard_render.R"
